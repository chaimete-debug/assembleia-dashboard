rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid))
        && get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.active != false
        && (
          get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.role == "admin"
          || get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.canEditAssemblyDate == true
        );
    }

    match /appConfig/assembleiaDistrital {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adminUsers/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
